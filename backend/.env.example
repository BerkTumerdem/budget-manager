# Leave MONGO_URI empty to use an in-memory MongoDB (local demo only).
# For production (Render), set a MongoDB Atlas URI.
MONGO_URI=

# Secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=change_me_to_a_long_random_string

# Port the API listens on (Render sets this automatically).
PORT=5000

# Frontend origin(s) allowed by CORS, comma-separated.
# Example: https://budget-manager.vercel.app
FRONTEND_URL=http://localhost:3000
