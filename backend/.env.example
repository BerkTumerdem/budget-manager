# Copy this file to .env and fill in your own values.

# MongoDB connection string.
# Leave empty to use an in-memory MongoDB (great for quick demos, data is lost on restart).
# Local MongoDB:   mongodb://localhost:27017/budgetapp
# MongoDB Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/budgetApp
MONGO_URI=

# Secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=change_me_to_a_long_random_string

# Port the API listens on (frontend expects 5000).
PORT=5000
